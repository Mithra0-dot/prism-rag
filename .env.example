# ─────────────────────────────────────────────────────────────────────
# PRISM — .env.example
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git. Only commit .env.example
# ─────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=development               # development | staging | production

# ── API Keys ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
HUGGINGFACE_TOKEN=hf_your-token-here  # optional, for private HF models

# ── LLM ──────────────────────────────────────────────────────────────
LLM_PROVIDER=openai                   # openai | huggingface
LLM_MODEL_NAME=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# ── Embeddings (default is FREE, runs locally) ────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── ChromaDB ─────────────────────────────────────────────────────────
CHROMA_COLLECTION_NAME=prism_documents

# ── Chunking ─────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval ─────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
HYBRID_SEARCH_ALPHA=0.5               # 0.0=BM25 only, 1.0=vector only

# ── Uploads ──────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50

# ── MLflow ───────────────────────────────────────────────────────────
MLFLOW_EXPERIMENT_NAME=PRISM-RAG-Experiments

# ── Server ───────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
BACKEND_URL=http://localhost:8000
